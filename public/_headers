# Override Cloudflare's default Permissions-Policy (removes interest-cohort warning)
/*
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Cache fingerprinted build assets for 1 year (URLs change on every deploy)
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Favicon files — cached long but MUST be revalidatable (Google ignores favicons with immutable)
/favicon.ico
  Cache-Control: public, max-age=604800
/favicon-32.png
  Cache-Control: public, max-age=604800
/icon.png
  Cache-Control: public, max-age=604800
/apple-touch-icon.png
  Cache-Control: public, max-age=604800
/icon-192.png
  Cache-Control: public, max-age=604800
/icon-512.png
  Cache-Control: public, max-age=604800
/malera-transparent.webp
  Cache-Control: public, max-age=604800

# Images and fonts — cached long, revalidatable
/*.png
  Cache-Control: public, max-age=31536000
/*.webp
  Cache-Control: public, max-age=31536000
/*.woff2
  Cache-Control: public, max-age=31536000
/*.svg
  Cache-Control: public, max-age=31536000
/*.ico
  Cache-Control: public, max-age=31536000

/manifest.json
  Cache-Control: public, max-age=86400
/*.txt
  Cache-Control: public, max-age=86400

# HTML pages: CDN-cached short-term with background revalidation
/ 
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, must-revalidate
/privacy/
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, must-revalidate
/terms/
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, must-revalidate
/starterdetails/
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, must-revalidate
/prodetails/
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, must-revalidate
/businessdetails/
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, must-revalidate
/enterprisedetails/
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, must-revalidate

# Override Cloudflare's default Permissions-Policy (removes interest-cohort warning)
/*
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Cache static assets for 1 year (fingerprinted URLs)
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Cache images and fonts aggressively
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# HTML pages: never cache (always fetch fresh)
/
  Cache-Control: no-cache, must-revalidate
/privacy
  Cache-Control: no-cache, must-revalidate
/terms
  Cache-Control: no-cache, must-revalidate

# Override Cloudflare's default Permissions-Policy (removes interest-cohort warning)
/*
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Cache static assets for 1 year (fingerprinted URLs)
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Cache images and fonts aggressively
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.svg
  Cache-Control: public, max-age=31536000, immutable
/*.txt
  Cache-Control: public, max-age=86400

# HTML pages: CDN-cached short-term with background revalidation
/ 
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, must-revalidate
/privacy/
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, must-revalidate
/terms/
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, must-revalidate
